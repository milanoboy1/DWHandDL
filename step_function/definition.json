{
  "Comment": "AiroInsights data ingestion — scheduled flight + weather fetch",
  "StartAt": "IngestData",
  "States": {
    "IngestData": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "${lambda_arn}",
        "Payload": {
          "fetch_flights": true,
          "max_pages": 3,
          "locations": [
            {"name": "zurich",    "lat": 47.3769, "lon":  8.5417},
            {"name": "frankfurt", "lat": 50.1109, "lon":  8.6821},
            {"name": "london",    "lat": 51.5072, "lon": -0.1276},
            {"name": "paris",     "lat": 48.8566, "lon":  2.3522}
          ]
        }
      },
      "ResultPath": "$.result",
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed"],
          "IntervalSeconds": 10,
          "MaxAttempts": 2,
          "BackoffRate": 2.0
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "IngestionFailed",
          "ResultPath": "$.error"
        }
      ],
      "End": true
    },
    "IngestionFailed": {
      "Type": "Fail",
      "Error": "IngestionFailed",
      "Cause": "Lambda invocation failed after retries"
    }
  }
}
